# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.
#
# Add new environment variables here when introduced,
# with a comment describing what each one is for.
#
# Example:
# NEXT_PUBLIC_SOME_API_KEY=        # Public API key for SomeService
# SOME_SECRET_KEY=                 # Server-only secret for SomeService
